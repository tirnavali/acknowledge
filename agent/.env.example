# Copy this file to agent/.env and fill in your values

# ── SendGrid ────────────────────────────────────────────────────────────────
# Get a free API key at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_key_here

# Email addresses
REPORT_TO_EMAIL=tran.ce.co@gmail.com
REPORT_FROM_EMAIL=acknowledge-agent@yourdomain.com  # must be a verified sender in SendGrid

# ── Ollama (hourly report agent) ─────────────────────────────────────────────
# Recommended: qwen3:8b  (4.6 GB VRAM, best structured output + reasoning)
# Lightweight:  qwen3:4b  (2.5 GB VRAM, runs alongside captioning)
OLLAMA_MODEL=qwen3:8b
OLLAMA_URL=http://localhost:11434

# How many hours of logs to include in each report
LOG_HOURS=1

# ── Alert agent (reactive watcher) ──────────────────────────────────────────
# How often to check the log file for new events (seconds)
ALERT_POLL_SECONDS=30

# Minimum minutes between repeated alerts for the same rule
# Prevents inbox flooding when an error is persistent
ALERT_COOLDOWN_MIN=60
