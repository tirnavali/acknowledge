# Copy this file to agent/.env and fill in your values

# SendGrid — get a free API key at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_key_here

# Email addresses
REPORT_TO_EMAIL=tran.ce.co@gmail.com
REPORT_FROM_EMAIL=acknowledge-agent@yourdomain.com  # must be verified in SendGrid

# Ollama settings (defaults shown — only change if you moved Ollama)
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_URL=http://localhost:11434

# How many hours of logs to include in each report (default: 1)
LOG_HOURS=1
