# Database Configuration (Required)
DB_USER=tirnavali
DB_PASSWORD=tirnavali_pass
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tirnavali_acknowledge

# Media Vault Path (Defaults to image_vault)
MEDIA_VAULT_PATH=media_vault

# Hugging Face Access Token (Optional, for downloading Qwen models if needed)
HF_TOKEN=

# Ollama Configuration (Optional, if using Gemma caption backend)
OLLAMA_URL=http://localhost:11434
OLLAMA_CAPTION_MODEL=gemma4:latest

# Sentry Monitoring (Optional)
SENTRY_DSN=

# Auto-update Test Trigger (Can be safely removed)
AUTO_UPDATE_TEST=true
